{
  "name": "agnes",
  "version": "0.28.0",
  "description": "AGNES — OpenCode Native Plugin: orchestrator plugin that routes tasks across 22 fused skills",
  "type": "module",
  "main": ".opencode/plugins/agnes.js",
  "repository": "github:nathwn12/agnes",
  "keywords": [
    "opencode",
    "plugin",
    "agent",
    "orchestrator",
    "skills"
  ],
  "license": "MIT",
  "scripts": {
    "bundle": "bun build src/plugin.ts --outfile .opencode/plugins/agnes.js --target bun",
    "bundle:watch": "bun build src/plugin.ts --outfile .opencode/plugins/agnes.js --target bun --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "release": "bun run scripts/release.ts --go",
    "release:dry": "bun run scripts/release.ts",
    "state-stats": "bun run scripts/state-stats.ts",
    "init-agnes": "bun run scripts/init-agnes.ts",
    "init-agnes:with-plan": "bun run scripts/init-agnes.ts --with-plan"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.15.5",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "typescript": "^5.7"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
