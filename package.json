{
  "name": "agnes",
  "version": "0.36.3",
  "description": "AGNES — OpenCode Native Plugin: orchestrator plugin with 9 bundled skills + 14 commands",
  "type": "module",
  "main": ".opencode/plugins/agnes.js",
  "repository": "github:nathwn12/agnes",
  "keywords": [
    "opencode",
    "plugin",
    "agent",
    "orchestrator",
    "skills"
  ],
  "license": "MIT",
  "scripts": {
    "bundle": "bun build src/plugin.ts --outfile .opencode/plugins/agnes.js --target bun",
    "bundle:watch": "bun build src/plugin.ts --outfile .opencode/plugins/agnes.js --target bun --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "worktree:sync": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/sync-worktree.ps1",
    "worktree:watch": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/watch-worktree.ps1",
    "release": "bun run scripts/release.ts --go",
    "release:dry": "bun run scripts/release.ts"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.15.5",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "typescript": "^5.7"
  }
}
